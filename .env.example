# =============================================================
# item-flow Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================

# ----- Database Configuration --------------------------------
# Database type: 'mongodb' or 'file' (standalone JSON-file mode)
DB_TYPE=mongodb

# Connection URI for MongoDB mode
MONGODB_URI=mongodb://mongo:27017/itemflow
# For production on Host B (container on same compose network):
# MONGODB_URI=mongodb://mongo:27017/itemflow
# For external MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/itemflow?retryWrites=true&w=majority

# ----- Backend -----------------------------------------------
PORT=3001
NODE_ENV=production

# JWT — generate a long random string, e.g.: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# ----- Frontend (Vite build-time) ----------------------------
# Points to the backend API. In production behind Nginx this is /api
VITE_API_URL=/api

# ----- Docker / GHCR -----------------------------------------
# GitHub Container Registry image names
DOCKER_REGISTRY=ghcr.io
GHCR_USERNAME=your-github-username
IMAGE_FRONTEND=ghcr.io/your-github-username/item-flow-frontend
IMAGE_BACKEND=ghcr.io/your-github-username/item-flow-backend

# ----- Deployment SSH ----------------------------------------
DEPLOY_HOST=ssh-erp.26i.uk
DEPLOY_USER=deploy
# Path on Host B where docker-compose.yml lives
DEPLOY_PATH=/opt/item-flow
# App port exposed on Host B (assign subdomain → this port)
APP_PORT=8088

# ----- GitHub Actions Secrets (set in repo Settings → Secrets)
# SSH_PRIVATE_KEY   — private key matching deploy user's authorized_keys on Host B
# SSH_KNOWN_HOSTS   — output of: ssh-keyscan ssh-erp.26i.uk
# GHCR_TOKEN        — GitHub PAT with packages:read + packages:write scope
# MONGODB_URI       — production MongoDB connection string
# JWT_SECRET        — production JWT secret
